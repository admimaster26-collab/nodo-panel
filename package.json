{
  "name": "nodo-operativo",
  "version": "1.0.14",
  "description": "NODO · OPERATIVO — Panel de operaciones",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.0"
  },
  "build": {
    "appId": "com.nodooperativo.app",
    "productName": "NODO · OPERATIVO",
    "files": [
      "main.js",
      "app-preload.js",
      "agent-preload.js",
      "chunior-bridge.js",
      "config.json",
      "services/**/*",
      "shared/**/*",
      "NODO · OPERATIVO LITE.htm",
      "index.html",
      "nodoSuperior/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
