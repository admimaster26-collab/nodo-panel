# ============================================================
# NODO · Panel operativo — plantilla de configuración
# Copiar a ".env" (oficina por defecto) o ".env.<ofi>" (multi-oficina en una PC).
# La OFICINA real la determina el login de Chunior del operador; estas vars son
# de infraestructura (workers, sesión, proxy).
# ============================================================

# Supabase (unificado · la anon key es pública por diseño, protegida por RLS)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_XXXXXXXX

# Oficina / PC (referencia; el operador igual entra a la suya por Chunior)
PC_CODIGO=P1
LANDING_PC_CODIGO=P1
OPERADOR=

# Workers de cola (apagados por defecto)
WORKERS_ENABLED=0
WORKER_OPERATIVO_ID=p1-operativo-01
WORKER_SYNC_ID=p1-sync-01
INTERVAL_MS_OPERATIVO=1200
INTERVAL_MS_SYNC=2500
AUTO_START_OPERATIVO=0
AUTO_START_SYNC=0

# Backoffices (mismas URLs; cada operador entra con la cuenta de SU oficina)
AGENT_LOGIN_URL=https://bo.casinodrex.com/login
AGENT_SEARCH_URL=https://bo.casinodrex.com/agents/user_search
AGENT_NEW_USER_URL=https://bo.casinodrex.com/agents/new_user
CHUNIOR_ENABLED=0
CHUNIOR_URL=https://bo.chunior.com/transacciones/
CHUNIOR_WINDOW_VISIBLE=1

# Timeouts
AUTOMATION_TIMEOUT_MS=45000
BUSCAR_USUARIO_TIMEOUT_MS=60000

# Sesión separada por oficina (si corrés más de una en la misma PC)
USER_DATA_DIR=user-data-p1

# Proxy por oficina (opcional; dejar PROXY_ENABLED=0 si no usa)
PROXY_ENABLED=0
PROXY_PROTOCOL=http
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_BYPASS_RULES=<local>
